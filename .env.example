# Copy to .env, fill in real values. NEVER commit .env.

# LLM providers (one or more)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# GCS bucket for conversation Markdown (ING-003 - required, fail-fast at boot).
GCS_BUCKET=archiviste-conversations-dev
# Optional fake-gcs-server endpoint for local/integration. Unset in prod => ADC.
# GCS_EMULATOR_HOST=http://localhost:4443
GOOGLE_APPLICATION_CREDENTIALS=

# DB (defaults match docker-compose)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/archiviste

# Redis (FOUND-002)
# Required: redis service refuses to start without a non-empty password.
# Local dev placeholder only -- never reuse in any deployed environment.
REDIS_PASSWORD=changeme

# Gateway
RUST_LOG=info,archiviste_gateway=debug
BIND_ADDR=0.0.0.0:8080
WORKERS_URL=http://localhost:8000
JWT_ED25519_PUBLIC_KEY_PEM=
JWT_ED25519_PRIVATE_KEY_PEM=

# LLM wrapper (GEN-001) - fail-fast at worker boot if any is empty/invalid.
LLM_PROVIDER=mistral
LLM_MODEL=mistral-small-latest
LLM_API_KEY=

# Internal worker -> worker base URLs (GEN-001 retrieve + ING-003 logger).
WORKERS_INTERNAL_BASE_URL=http://localhost:8000
CONVERSATION_INTERNAL_BASE_URL=http://localhost:8000

# Google Drive sync (ING-013) - set one of GDRIVE_SA_KEY_JSON or GOOGLE_APPLICATION_CREDENTIALS above.
# GDRIVE_SA_KEY_JSON=
# GDRIVE_ROOT_FOLDER_ID=

# UI-002 PR1: GCS V4 signed URL signing for /v1/conversations/{id}/signed-url.
# SA must have roles/storage.objectAdmin scoped to GCS_BUCKET only (vision §123).
GCS_SIGNING_SA_EMAIL=archiviste-runtime@archiviste-nocilia-dev.iam.gserviceaccount.com
# Private key in PKCS#8 PEM. Load from Secret Manager in prod, NEVER commit real key.
# Dev/test: generate jetable via `openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out k.pem && openssl pkcs8 -topk8 -nocrypt -in k.pem`.
# Multi-line PEM in .env: replace newlines with literal `\n` OR use docker-compose env_file with `KEY="$(cat k.pem)"`.
GCS_SIGNING_PRIVATE_KEY_PEM=
