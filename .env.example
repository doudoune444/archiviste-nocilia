# Copy to .env, fill in real values. NEVER commit .env.

# LLM providers (one or more)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# GCS bucket for conversation Markdown
GCS_BUCKET_CONVERSATIONS=archiviste-conversations-dev
GOOGLE_APPLICATION_CREDENTIALS=

# DB (defaults match docker-compose)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/archiviste

# Redis (FOUND-002)
# Required: redis service refuses to start without a non-empty password.
# Local dev placeholder only -- never reuse in any deployed environment.
REDIS_PASSWORD=changeme

# Gateway
RUST_LOG=info,archiviste_gateway=debug
BIND_ADDR=0.0.0.0:8080
WORKERS_URL=http://localhost:8000
