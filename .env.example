# Google Drive Sync — Service Account Credentials (ING-013)
# Set ONE of the following to authenticate:

# Option A: Inline JSON content of the service account key file.
# GDRIVE_SA_KEY_JSON=

# Option B: Path to the service account key file on disk.
# GOOGLE_APPLICATION_CREDENTIALS=

# Google Drive root folder ID to sync (required at runtime).
# GDRIVE_ROOT_FOLDER_ID=
